<!DOCTYPE html>
<html lang="en">
<head>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/style.css">
    
    <title>MovieVault - Home</title>
</head>
<body class="relative">
<div class="grid grid-cols-1 md:grid-cols-[30%_70%] lg:grid-cols-[20%_80%] h-screen w-full">
    <!-- Sidebar -->
    <%- include('../sideBar') %>

    <!-- Main Content -->
    <div class="bg-zinc-100 overflow-auto p-8 flex flex-col  md:gap-8">
        <header class="fixed top-0 left-0 right-0 bg-white shadow-lg rounded-xl p-4 flex justify-between  md:hidden">
            <h1 class="text-2xl font-bold text-blue-950 leading-tight">Movie Vault</h1>
            <button
            id="menu-btn"
            >
            <i
            class="fa-solid fa-bars text-lg"
            ></i>
            </button>
        </header>
       <%- include('../aside/aside') %>
        <!-- Welcome Card -->
        <div class="mt-12 md:mt-0 bg-white shadow-lg rounded-xl border border-gray-200 pt-8 pb-12 px-6 flex flex-col md:flex-row md:gap-2 lg:gap-10 items-center">
            
            <!-- Left Side - Text -->
            <div class="flex-1">
                <h1 class="text-4xl font-bold text-blue-950 leading-tight">
                    Hello, Welcome to The Movie<span class="text-purple-500">Vault</span>
                </h1>
                <p class="text-gray-600 mt-4 text-lg leading-relaxed">
                    MovieVault helps you manage your movies, directors, and genres all in one place. 
                    Add your favorite movies, assign them to genres, and explore director details.
                </p>
                <a href="/movies" 
                   class="inline-flex items-center mt-8 bg-blue-600 hover:bg-blue-700 text-white font-semibold text-lg px-8 py-4 rounded-2xl transition gap-3">
                    <i class="fas fa-film"></i>
                    Explore Movies
                </a>
            </div>

            <!-- Right Side - Simple Logo Style -->
            <div class="flex-shrink-0 flex items-center justify-center w-full md:w-96 lg:w-[380px]  ">
                <svg width="380" height="220" viewBox="0 0 380 320" fill="none" xmlns="http://www.w3.org/2000/svg" class="drop-shadow-2xl">
                    <!-- Background Circle -->
                    <circle cx="190" cy="160" r="140" fill="#1E2937" fill-opacity="0.95"/>
                    <!-- Film Reel -->
                    <circle cx="190" cy="160" r="95" stroke="#6366F1" stroke-width="18"/>
                    <circle cx="190" cy="160" r="95" stroke="#A855F7" stroke-width="8" stroke-dasharray="10 15"/>
                    
                    <!-- Inner Movie Frame -->
                    <rect x="110" y="100" width="160" height="120" rx="12" fill="#F1F5F9" stroke="#1E2937" stroke-width="14"/>
                    <!-- Play Icon -->
                    <polygon points="165,135 165,195 225,165" fill="#1E2937"/>
                    
                    <!-- Stars -->
                    <circle cx="130" cy="85" r="8" fill="#FBBF24"/>
                    <circle cx="250" cy="85" r="8" fill="#FBBF24"/>
                    <circle cx="105" cy="210" r="6" fill="#FBBF24"/>
                    <circle cx="270" cy="215" r="7" fill="#FBBF24"/>
                    
                   
                </svg>
            </div>
        </div>
        <div class="mt-6 md:mt-0 flex justify-center">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 w-full max-w-5xl">
                    <div 
                    class="bg-gradient-to-br from-blue-300 to-purple-300 rounded-xl shadow-sm md:shadow-lg p-6 flex flex-col gap-4 items-center text-center hover:-translate-y-1 hover:shadow-xl transition-all duration-300 cursor-pointer">
                    <div
                    class="rounded-[50%] p-2 bg-white/20 w-12 h-12"
                    > <i class="fa-solid fa-film text-xl w-6 text-white "></i></div>
                    <h1 class="font-semibold text-white text-4xl"><%=movies.length%></h1>
                    <h1 class="font-semibold text-white text-2xl">All Movies</h1>
                    </div>
                    <div 
                    class="bg-gradient-to-br from-blue-300 to-purple-300 rounded-xl shadow-sm md:shadow-lg p-6 flex flex-col gap-4 items-center text-center hover:-translate-y-1 hover:shadow-xl transition-all duration-300 cursor-pointer">
                    <div
                    class="rounded-[50%] p-2 bg-white/20 w-12 h-12"
                    >
                     <i class="fas fa-video text-white text-xl w-6"></i></div>
                    <h1 class="font-semibold text-white text-4xl"><%=directors.length%></h1>
                    <h1 class="font-semibold text-white text-2xl">All Directors</h1>
                    </div>
                    <div 
                    class="bg-gradient-to-br from-blue-300 to-purple-300 rounded-xl shadow-sm md:shadow-lg p-6 flex flex-col gap-4 items-center text-center hover:-translate-y-1 hover:shadow-xl transition-all duration-300 cursor-pointer">
                    <div
                    class="rounded-[50%] p-2 bg-white/20 w-12 h-12"
                    > 
                     <i class="fas fa-tags text-white text-xl w-6"></i></div>
                    <h1 class="font-semibold text-white text-4xl"><%=genres.length%></h1>
                    <h1 class="font-semibold text-white text-2xl">All Geners</h1>
                    </div>
                    
                    
            </div>
        </div>
    </div>
</div>
<script src="/home.js"></script>
</body>
</html>

<aside 
    id="mobilesideBar"
    class="flex flex-col gap-4 absolute p-4 top-0 left-0 h-screen z-20 bg-white w-72 shadow-2xl border-l-2 border-solid border-blue-500 -translate-x-full transition-transform duration-300 ease-in-out md:hidden">
    <h1>fuck</h1>
</aside>