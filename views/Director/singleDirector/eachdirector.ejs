<!DOCTYPE html>
<html lang="en">
<head>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/style.css">
    
    <title>Inventory Application</title>
</head>
<body class="m-0">
    <div class="grid grid-cols-[20%_80%] h-screen w-full">
        <%- include('../../sideBar') %>
        <div class="bg-zinc-100 overflow-auto pt-8 px-4 pb-2 flex flex-col gap-8 min-h-screen">
                 <div class="bg-white pb-8 shadow-xl rounded-xl  border-2 flex flex-col gap-8 justify-center py-8 px-3 ">
                        <h1 class="text-3xl font-bold"><%=directorname%></h1>
                        <p class="text-gray-500">Movies In This Category</p>
                        <div class="flex  gap-8 flex-wrap justify-center ">
                                <%singleDirector.map((eachDirector)=> {
                                    %>
                                  <img 
                        src="<%= eachDirector.imageurl %>" 
                        alt="<%= eachDirector.moviename || 'Movie' %>"
                        width="250" 
                        height="250"
                        onerror="this.style.display='none';"
                        style="object-fit: cover; border-radius: 8px; box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1);"
                    >
                                    <%
                                })%>
                        </div>
                 </div>
               
        </div>
    </div>
    
</body>
</html>