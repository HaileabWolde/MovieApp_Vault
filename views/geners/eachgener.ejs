<!DOCTYPE html>
<html lang="en">
<head>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/style.css">
    <title>Inventory Application</title>
</head>
<body class="m-0">

    <div class="grid grid-cols-1 md:grid-cols-[30%_70%] lg:grid-cols-[20%_80%] h-screen w-full">
        <%- include('../sideBar') %>

        <div class="bg-zinc-100 overflow-auto pt-8 px-4 pb-2 flex flex-col gap-8 min-h-screen">
            <header 
    class="fixed top-0 left-0 right-0 bg-white shadow-lg rounded-xl p-4 flex justify-between  md:hidden">
            <h1 class="text-2xl font-bold text-blue-950 leading-tight">Movie Vault</h1>
            <button
            id="menu-btn"
            >
            <i
            class="fa-solid fa-bars text-lg"
            ></i>
            </button>
        </header>
          <%-include('../aside/aside') %>
            <div class="mt-12 sm:mt-0 bg-white shadow-xl rounded-xl border-2 p-8 flex flex-col gap-4">
                
                <h1 class="text-3xl font-bold"><%= genername %></h1>
                <p class="text-gray-500">Movies In This Category</p>

                <table class="min-w-full border border-gray-200">
                    <thead class="bg-gray-50 border-b">
                        <tr>
                            <th class="text-left px-6 py-3 font-semibold">Name</th>
                            <th class="text-left px-6 py-3 font-semibold">Type</th>
                            <th class="text-left px-6 py-3 font-semibold">Priority</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (singleGener && singleGener.length > 0) { %>
                            <% singleGener.forEach((movie) => { %>
                                <tr
                                onclick="window.location.href='/movies/<%= movie.movieid %>'" 
                                class="border-b hover:bg-gray-50 cursor-pointer">
                                    <td class="px-6 py-3">
                                        <p class="font-semibold"><%= movie.moviename %></p>
                                    </td>
                                    <td class="px-6 py-3">
                                        <p class="text-gray-500"><%= movie.typeofmovie %></p>
                                    </td>
                                    <td class="px-6 py-3">
                                        <p class="text-gray-500"><%= movie.priority %></p>
                                    </td>
                                </tr>
                            <% }); %>
                        <% } else { %>
                            <tr>
                                <td colspan="3" class="px-6 py-8 text-center">
                                    <p class="text-gray-400 text-sm italic">
                                        No Movies In This Genre
                                    </p>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>

            </div>
        </div>
    </div>
 <script src="/genre.js"></script>   
</body>
</html>