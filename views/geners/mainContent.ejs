<div class="bg-zinc-100 overflow-auto pt-4 px-4 pb-2 flex  flex-col gap-8 min-h-screen">
    <div class="bg-white pb-8 shadow-xl rounded-xl  border-2 flex flex-col justify-center py-8 px-3">
                   <h1 class="text-3xl font-bold ">Geners</h1>
                    <p class="text-gray-500">Showing <%=geners.length%> Geners</p>
    </div>
    <div class="bg-white  shadow-xl rounded-xl border-2 flex flex-col gap-2 justify-between cursor-pointer">
        <%geners.map((gener)=> {
            %>
            <div class="flex justify-between border-b-2 px-4 py-4 items-center">
                <a  href="/geners/<%=gener.genername%>/<%= gener.genreid%>">
                         <h1 class="font-semibold"><%=gener.genername%></h1>
                </a>
               
                <div class="flex gap-4 items-center justify-center px-4">
                        <button class="text-gray-500">
                              <i class="fas fa-edit"></i>
                        </button>
                        <button class="text-gray-500">
                            <i class="fa-solid fa-trash"></i>
                        </button>
                </div>
            </div>
            <%
        })%>
    </div>
</div>