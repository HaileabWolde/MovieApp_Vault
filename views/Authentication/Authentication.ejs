<!DOCTYPE html>
<html lang="en">
<head>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/style.css">
    
    <title>Inventory Application</title>
</head>
<body class="m-0 bg-zinc-100 grid place-items-center h-screen">
   <form
   method="POST"
   action="/auth/check"
   class="relative bg-white shadow-xl rounded-xl p-10 border-2 w-full max-w-md flex flex-col gap-8 items-center"
   >
   <a 
   href="/movies"
   class="absolute top-6 right-6 bg-zinc-100 rounded-[50%] p-2 flex items-center justify-center w-12 h-12  hover:bg-zinc-200"
   >
    <i class="fa-solid fa-xmark text-gray-600 fa-2x"></i>
   </a>
    <h1 class=" font-bold text-2xl ">Admin Verification </h1>
    <p class="text-gray-500">Please enter your admin password to access edit and delete options. </p>
    <span class="w-full flex flex-col ">
         <label 
         for="Admincheck" class="block text-lg font-bold text-zinc-700 mb-2">
            Password
        </label>
        <input 
            type="text" 
            id="Admincheck" 
            name="Admincheck"
            class=" outline-none w-full border-2 border-zinc-300 focus:border-violet-500 focus:ring-violet-500 rounded-2xl px-5 py-3 text-base transition-all">
          <input type="hidden" name="id" id="id" value="<%=id%>">
          <input type="hidden" name="type" id="type" value="<%=type%>">
         <span id="AdmincheckError" class="text-red-500 text-sm mt-1"></span>       
        <button
        class="bg-blue-500 p-2 rounded-xl mt-3" 
        type="submit"
       >
                              
                                     <h1 class="text-white font-bold text-lg text-center">Confrim</h1>
        </button>
              
    </span>
   </form>
   <script>
    // Show error modal if error exists
    window.onload = function (){
        const error = "<%- error || '' %>"
              if (error) {
            
            document.getElementById('AdmincheckError').innerHTML = error;
           
        }
    }
   </script>
</body>
</html>