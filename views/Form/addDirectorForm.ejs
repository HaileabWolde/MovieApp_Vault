<!DOCTYPE html>
<html lang="en">
<head>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/style.css">
    
   <title>Movie Vault App</title>
</head>
<body>
    <div id="errorModal" class="hidden fixed inset-0 bg-black/70 flex items-center justify-center ">
    <div class="bg-white rounded-3xl shadow-2xl max-w-md w-full mx-4 overflow-hidden">
        <!-- Header -->
        <div class="bg-red-600 px-6 py-4 text-white flex items-center gap-3">
            <i class="fa-solid fa-circle-exclamation text-2xl"></i>
            <h3 class="font-semibold text-lg">Duplicate Director</h3>
        </div>
        
        <!-- Body -->
        <div class="p-8 text-center">
            <p id="modalErrorMessage" class="text-zinc-700 text-lg leading-relaxed">
                <!-- Error message injected here -->
            </p>
        </div>

        <!-- Footer -->
        <div class="border-t px-6 py-4 flex justify-end">
            <button onclick="closeModal()" 
                    class="bg-zinc-800 hover:bg-zinc-900 text-white px-8 py-3 rounded-2xl font-medium transition-all">
                Try Another Name
            </button>
        </div>
    </div>
</div>
<div class="grid grid-cols-1 md:grid-cols-[30%_70%] lg:grid-cols-[20%_80%] h-screen w-full ">
    <!-- Sidebar -->
     <%- include('../sideBar') %>
     <div
     class="bg-zinc-100 overflow-auto  flex  flex-col  justify-center p-12 lg:p-0"
     >
      <header 
    class="fixed top-0 left-0 right-0 bg-white shadow-lg rounded-xl p-4 flex justify-between  md:hidden">
            <h1 class="text-2xl font-bold text-blue-950 leading-tight">Movie Vault</h1>
            <button
            id="menu-btn"
            >
            <i
            class="fa-solid fa-bars text-lg"
            ></i>
            </button>
        </header>
          <%-include('../aside/aside') %>
        <div class="bg-white shadow-xl rounded-xl p-12 border-2  justify-around w-full max-w-2xl mx-auto">
           
              <form 
                    method="POST" 
                    action="<%=singleDirector ? `/director/editdirector/${singleDirector[0].directorid}` : '/director/add' %>" 
                    id="mydirectorform" 
                    class="flex flex-col gap-8 relative"
                   >
                  <a 
   href="/movies"
   class="absolute top-0 right-0 bg-zinc-100 rounded-[50%] p-2 sm:p-0 flex items-center justify-center w-12 h-12  hover:bg-zinc-200"
   >
    <i class="fa-solid fa-xmark text-gray-600 fa-2x"></i>
   </a>
                          <h1 class="text-3xl font-bold text-zinc-800"><%= singleDirector ? 'Edit Existing Director' : 'Add New Director'%></h1>
                         <span>
                                <label for="directorname" class="block text-sm font-medium text-zinc-700 mb-2">
                                 Director Name
                                </label>
                                <input 
                                    type="text" 
                                    id="directorname" 
                                    name="directorname"
                                    value="<%=singleDirector?.[0].directorname%>"
                                    placeholder="Enter Director name"
                                    class=" outline-none w-full border border-zinc-300 focus:border-violet-500 focus:ring-violet-500 rounded-2xl px-5 py-4 text-base transition-all">
                                       <span id="directornameError" class="text-red-500 text-sm mt-1"></span>
                             
            </span>
                <button
                type="submit"
                 class="self-end  w-[100%] sm:w-[50%] bg-violet-600 hover:bg-violet-700 text-white font-semibold text-lg py-3 rounded-2xl transition-all duration-200 flex items-center justify-center gap-3 shadow-lg shadow-violet-500/30">
                 <i class="fa-solid fa-plus"></i>
                <h1 ><%= singleDirector ? 'Edit Director' : 'Add A Director'%></h1>
                </button>
                   </form>
           
        </div>
    </div>
</div>
<script>
    // Show error modal if error exists
    window.onload = function() {
        const error = "<%- error || '' %>";
        if (error) {
            
            document.getElementById('modalErrorMessage').innerHTML = error;
            document.getElementById('errorModal').classList.remove('hidden');
        }
    }

    function closeModal() {
        document.getElementById('errorModal').classList.add('hidden');
    }

    // Optional: Close modal when pressing Escape key
    document.addEventListener('keydown', function(e) {
        if (e.key === "Escape") {
            closeModal();
        }
    });
</script>
 <script src="/director.js"></script>
</body>
</html>