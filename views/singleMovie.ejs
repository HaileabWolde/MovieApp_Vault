<!DOCTYPE html>
<html lang="en">
<head>
     <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <meta charset="UTF-8">
     
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
   
   <link rel="stylesheet" href="/style.css">        <!-- Your custom CSS second -->
  
   
   <title>Movie Vault App</title>
</head>
<body class="m-0">
     <div 
 id="dialogModal" 
 class="hidden fixed inset-0 bg-black/70 flex items-center justify-center ">
   
    <dialog 
    id="dialog"
    class="justify-self-center bg-white rounded-3xl shadow-2xl max-w-md w-full mx-4 overflow-hidden">
        <!-- Header -->
        <div class="bg-red-600 px-6 py-4 text-white flex items-center gap-3">
            <i class="fa-solid fa-circle-exclamation text-2xl"></i>
            <h3 class="font-semibold text-lg">Are You Sure You Want To Delete This Movie?</h3>
        </div>
        
        <!-- Body -->
        <form
         method="GET" 
        action="/movie/delete"
        id="mydialogform"
        class="p-8 text-center flex justify-between">
         <input type="hidden" name="id" id="movieIdInput" value="">
          <input type="hidden" name="type" id="movieTypeInput" value="movies">
            <button 
                    class="outline-none"
                   type="submit">Delete</button>
            <button
                   type="button"  
                   id="cancelButton">Cancel</button>
        </form>

      
    </dialog>
</div>
    <div class="grid grid-cols-1 md:grid-cols-[30%_70%] lg:grid-cols-[20%_80%] h-screen w-full">
        
        <!-- Sidebar -->
       <%- include('sideBar') %>

        <div class="bg-zinc-100 overflow-auto pt-4 px-12 pb-2 flex  flex-col gap-8">
            <header 
    class="fixed top-0 left-0 right-0 bg-white shadow-lg rounded-xl p-4 flex justify-between  md:hidden">
            <h1 class="text-2xl font-bold text-blue-950 leading-tight">Movie Vault</h1>
            <button
            id="menu-btn"
            >
            <i
            class="fa-solid fa-bars text-lg"
            ></i>
            </button>
        </header>
          <%-include('./aside/aside') %>
            <div class="mt-14 sm:mt-0 bg-white shadow-xl rounded-xl p-8 lg:p-12 border-2  flex flex-col justify-around">
                <div class="flex flex-col gap-4 sm:gap-0 sm:flex-row justify-between mb-4 ">
                    <div>
                         <% singleMovie.map((movie)=>{
                    %>

                    <h1 class="text-3xl font-bold">
                        <%=movie.moviename.toUpperCase()%>
                    </h1>
                    <p class="text-gray-500">
                        <%=movie.description%>
                    </p>
                    <%
                })%>
                    </div>
                    <div class=" flex  gap-4 items-center justify-end sm:justify-center">
                            <%singleMovie.map((movie)=> {
                                    %>
                                    <a 
                                                href="/movies/edit/<%=movie.movieid%>?type=editmovies"
                                                class="text-gray-500">
                                                         <i
                                                     
                                                      class="fas fa-edit fa-2x"></i>
                                                </a>
                                                <a 
                                                 id="deleteMovieButton" 
                                                 data-movie-id = "<%=movie.movieid%>"
                                                class="text-gray-500 cursor-pointer">
                                                        <i class="fa-solid fa-trash fa-2x"></i>
                                                </a>
                                    <%
                            })%>
                                                
                                                 
                    </div>
                </div>
               <div class="flex flex-col lg:flex-row gap-4 items-center justify-between">
                    <%singleMovie.map((movie)=> {
                        %>
                        <img src="<%= movie.imageurl %>" 
                             alt=""
                            width="280" 
                            height="280"
                            onerror="this.style.display='none';"
                            style="object-fit: cover; border-radius: 8px;">
                        <%
                    })%>
                   <div class="flex flex-col gap-6">
                     <!-- Categories -->
                                 <div>
                                     <div class="flex items-center gap-3 mb-3">
                                              <i class="fas fa-tags text-violet-600 text-2xl"></i>
                                        <h2 class="text-xl font-semibold text-gray-800">Geners</h2>
                                     </div>
        
                                         <div class="flex flex-wrap gap-2">
                                            <% if (categories && categories.length > 0) { %>
                                        <% categories.forEach(category => { %>
                                            <span class="inline-flex items-center px-4 py-2 bg-violet-100 text-violet-700 font-medium rounded-full text-sm">
                                                <%= category.genername %>
                                            </span>
                                        <% }); %>
                                    <% } else { %>
                                        <p class="text-gray-400 italic">No genres for this movie.</p>
                                    <% } %>
                                         </div>
                                  </div>

                  <!-- Directors -->
                                 <div>
                                         <div class="flex items-center gap-3 mb-3">
                                             <i class="fas fa-video text-amber-600 text-2xl"></i>
                                            <h2 class="text-xl font-semibold text-gray-800">Director</h2>
                                         </div>
        
                                          <div class="flex flex-wrap gap-3">
                                    <% if (directors && directors.length > 0) { %>
                                        <% directors.forEach(director => { %>
                                            <div class="flex items-center gap-3 bg-white px-5 py-3 rounded-2xl shadow-sm border border-gray-100 hover:shadow-md transition-all">
                                                <div class="w-9 h-9 bg-amber-100 text-amber-600 rounded-xl flex items-center justify-center">
                                                    <i class="fas fa-user-tie"></i>
                                                </div>
                                                <p class="font-semibold text-gray-800"><%= director.directorname %></p>
                                            </div>
                                        <% }); %>
                                    <% } else { %>
                                        <p class="text-gray-400 italic">No directors assigned to this movie.</p>
                                    <% } %>
                                </div>
                                  </div>
</div>
               </div>
            </div>

        </div>
    </div>
 <script src="/movie.js"></script>
</body>
</html>