<!DOCTYPE html>
<html lang="en">
<head>
     <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <meta charset="UTF-8">
     
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
   
   <link rel="stylesheet" href="/style.css">        <!-- Your custom CSS second -->
  
   
    <title>Inventary Application</title>
</head>
<body class="m-0">

    <div class="grid grid-cols-[20%_80%] h-screen w-full">
        <!-- Sidebar -->
       <%- include('sideBar') %>

        <div class="bg-zinc-100 overflow-auto pt-4 px-12 pb-2 flex  flex-col gap-8">
            <div class="bg-white shadow-xl rounded-xl p-12 border-2 h-full">
                <div class="flex justify-between ">
                    <div>
                         <% singleMovie.map((movie)=>{
                    %>

                    <h1 class="text-3xl font-bold">
                        <%=movie.moviename.toUpperCase()%>
                    </h1>
                    <p class="text-gray-500">
                        <%=movie.description%>
                    </p>
                    <%
                })%>
                    </div>
                    <div class=" flex gap-4 items-center justify-center">
                                                <button class="text-gray-500">
                                                         <i
                                                     
                                                      class="fas fa-edit fa-2x"></i>
                                                </button>
                                                <button class="text-gray-500">
                                                        <i class="fa-solid fa-trash fa-2x"></i>
                                                </button>
                                                 
                    </div>
                </div>
               
            </div>

        </div>
    </div>

</body>
</html>