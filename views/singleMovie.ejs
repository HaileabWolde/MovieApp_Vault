<!DOCTYPE html>
<html lang="en">
<head>
     <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <meta charset="UTF-8">
     
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
   
   <link rel="stylesheet" href="/style.css">        <!-- Your custom CSS second -->
  
   
    <title>Inventary Application</title>
</head>
<body class="m-0">

    <div class="grid grid-cols-[20%_80%] h-screen w-full">
        <!-- Sidebar -->
       <%- include('sideBar') %>

        <div class="bg-zinc-100 overflow-auto pt-4 px-12 pb-2 flex  flex-col gap-8">
            <div class="bg-white shadow-xl rounded-xl p-12 border-2 h-full flex flex-col justify-around">
                <div class="flex justify-between ">
                    <div>
                         <% singleMovie.map((movie)=>{
                    %>

                    <h1 class="text-3xl font-bold">
                        <%=movie.moviename.toUpperCase()%>
                    </h1>
                    <p class="text-gray-500">
                        <%=movie.description%>
                    </p>
                    <%
                })%>
                    </div>
                    <div class=" flex gap-4 items-center justify-center">
                                                <button class="text-gray-500">
                                                         <i
                                                     
                                                      class="fas fa-edit fa-2x"></i>
                                                </button>
                                                <button class="text-gray-500">
                                                        <i class="fa-solid fa-trash fa-2x"></i>
                                                </button>
                                                 
                    </div>
                </div>
               <div class="flex gap-4 items-center justify-between">
                    <%singleMovie.map((movie)=> {
                        %>
                        <img src="<%= movie.imageurl %>" 
                             alt=""
                            width="280" 
                            height="280"
                            onerror="this.style.display='none';"
                            style="object-fit: cover; border-radius: 8px;">
                        <%
                    })%>
                   <div class="flex flex-col gap-6">
                     <!-- Categories -->
                                 <div>
                                     <div class="flex items-center gap-3 mb-3">
                                              <i class="fas fa-tags text-violet-600 text-2xl"></i>
                                        <h2 class="text-xl font-semibold text-gray-800">Geners</h2>
                                     </div>
        
                                         <div class="flex flex-wrap gap-2">
                                             <% categories.map((category) => { %>
                                                     <span class="inline-flex items-center px-4 py-2 bg-violet-100 text-violet-700 font-medium rounded-full text-sm shadow-sm">
                                                              <%= category.genername %>
                                                    </span>
                                               <% }) %>
                                         </div>
                                  </div>

                  <!-- Directors -->
                                 <div>
                                         <div class="flex items-center gap-3 mb-3">
                                             <i class="fas fa-video text-amber-600 text-2xl"></i>
                                            <h2 class="text-xl font-semibold text-gray-800">Director</h2>
                                         </div>
        
                                          <div class="flex flex-wrap gap-3">
                                                <% directors.map((director) => { %>
                                         <div class="flex items-center gap-3 bg-white px-5 py-3 rounded-2xl shadow-sm border border-gray-100 hover:shadow-md transition-all">
                                                 <div class="w-9 h-9 bg-amber-100 text-amber-600 rounded-xl flex items-center justify-center">
                                                        <i class="fas fa-user-tie"></i>
                                                 </div>
                                                  <div>
                                                     <p class="font-semibold text-gray-800"><%= director.directorname %></p>
                                                  </div>
                                        </div>
                                                 <% }) %>
                                         </div>
                                  </div>
</div>
               </div>
            </div>

        </div>
    </div>

</body>
</html>