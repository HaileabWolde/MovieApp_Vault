  <!-- Main Content -->
        <div class="bg-zinc-100 overflow-auto pt-4 px-4 pb-2 flex  flex-col gap-8">
                <div class="bg-white pb-8 shadow-xl rounded-xl  border-2 flex flex-col justify-center py-8 px-3">
                   <h1 class="text-3xl font-bold ">Movies</h1>
                    <p class="text-gray-500">Showing <%=movies.length%> Movies</p>
                </div>
                <div class="bg-white h-full shadow-xl rounded-xl border-2">
                      <table class="min-w-full ">
                        <thead class="bg-gray-50 border-b">
                                 <tr >
                                <th class="text-left px-6 py-3  font-semibold">Title & Director</th>
                                <th class="text-left px-6 py-3 font-semibold">Geners</th>
                                <th class="text-left px-6  font-semibold">Actions</th>
                                 </tr>
                        </thead>
                           <tbody class="">
                                <% movies.map((movie)=> {
                                   %>
                                   <tr class="bg-gray-50 border-b cursor-pointer">
                                        <td class="px-6 py-3 flex gap-4">
                                            <a href="/movies/<%=movie.movieid%>">
                                                <img src="<%= movie.imageurl %>" 
                                                 alt=""
                                                width="80" 
                                                 height="80"
                                                    onerror="this.style.display='none';"
                                                style="object-fit: cover; border-radius: 8px;">
                                                <div class="flex flex-col justify-center">
                                                           <p class="font-semibold"><%=movie.moviename.toUpperCase()%></p>
                                           
                                                         <p class="text-gray-500">By <%=movie.directorname%></p>
                                                </div>
                                            </a>
                                            
                                         
                                        </td>
                                        <td class="px-6 py-3">
                                           <% 
                                           // Filter genres that belong to current movie
                                          const movieGenres = genres.filter(g => g.movieid === movie.movieid);
                                             %>
                                         
                                         <% if (movieGenres.length > 0) { %>
                                                   <% movieGenres.forEach(genre => { %>
                                                             <p class="font-semibold"><%= genre.genername%></p>
                                             <% }); %>
                                         <% } 
                                         else { %>
                                                    <p class="text-gray-400 text-sm italic">No genres</p>
                                         <% } %>
                                        </td>
                                        <td class="">
                                            <div class=" flex gap-4 items-center justify-center w-[50%]">
                                                <button class="text-gray-500">
                                                         <i
                                                     
                                                      class="fas fa-edit"></i>
                                                </button>
                                                <button class="text-gray-500">
                                                        <i class="fa-solid fa-trash"></i>
                                                </button>
                                                 
                                            </div>
                                        
                                        </td>
                                   </tr>
                        
                             <%
                            }) %>
                                
                           </tbody>
                            
                    </table>
                </div>
            <% /*movies.map((movie)=> {
                %>
                <h1><%=movie.moviename%></h1>
                <%
            }) */%>
            <!-- Content here -->
        </div>